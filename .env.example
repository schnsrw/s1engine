# ═══════════════════════════════════════════════════
# Rudra Office — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy to .env:  cp .env.example .env
#
# The unified s1-server serves everything on one port:
#   - Static editor files, REST API, WebSocket collab, Admin panel
# No separate relay or Node.js process is needed.

# ─── Server ──────────────────────────────────────
S1_PORT=8080
S1_STORAGE=local
S1_DATA_DIR=./data

# ─── Authentication ────────────────────────────────
S1_AUTH_ENABLED=false
S1_JWT_SECRET=           # Generate: openssl rand -base64 32
S1_ALLOW_ANONYMOUS=true

# ─── Admin Panel ──────────────────────────────────
S1_ADMIN_USER=admin
S1_ADMIN_PASS=changeme   # CHANGE for production!

# ─── Limits ────────────────────────────────────────
S1_MAX_UPLOAD_SIZE=67108864

# ─── CORS ──────────────────────────────────────────
# S1_CORS_ORIGINS=https://app.example.com

# ─── Logging ───────────────────────────────────────
RUST_LOG=s1_server=info,tower_http=info
