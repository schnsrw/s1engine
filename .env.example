# ═══════════════════════════════════════════════════
# s1engine — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and adjust for your deployment.
# All values shown are defaults.

# ─── Editor ────────────────────────────────────────
# Port for the web editor static files
PORT=8787

# Node.js environment
NODE_ENV=production

# API server URL (editor connects to this for document operations)
S1_API_URL=http://localhost:8080/api/v1

# WebSocket URL (editor connects to this for collaboration)
# Leave empty for standalone mode (built-in relay)
S1_RELAY_URL=ws://localhost:8080/ws/collab

# ─── s1-server (REST API) ─────────────────────────
# Port for the REST API server
S1_PORT=8080

# Storage backend: "local" or "memory"
S1_STORAGE=local

# Data directory for local storage
S1_DATA_DIR=./data

# ─── Admin Panel ──────────────────────────────────
# Admin credentials (both required to enable /admin/dashboard)
# Change these in production!
S1_ADMIN_USER=admin
S1_ADMIN_PASS=changeme

# ─── Authentication ────────────────────────────────
# Enable authentication (true/false)
S1_AUTH_ENABLED=false

# JWT secret key for HS256 token validation
# Generate with: openssl rand -base64 32
S1_JWT_SECRET=

# Allow anonymous access (read-only)
S1_ALLOW_ANONYMOUS=true

# ─── Collaboration ─────────────────────────────────
# WebSocket relay URL (for editor to connect to)
S1_RELAY_URL=ws://localhost:8787

# Maximum operations in offline buffer before warning
S1_MAX_OFFLINE_OPS=10000

# Room auto-save interval (seconds)
S1_ROOM_SAVE_INTERVAL=30

# ─── Limits ────────────────────────────────────────
# Maximum upload file size (bytes)
S1_MAX_UPLOAD_SIZE=67108864

# Maximum paste paragraphs
S1_MAX_PASTE_PARAGRAPHS=10000

# ─── CORS ──────────────────────────────────────────
# Allowed origins (comma-separated, or * for all)
S1_CORS_ORIGINS=*

# ─── Logging ───────────────────────────────────────
# Log level: trace, debug, info, warn, error
S1_LOG_LEVEL=info
RUST_LOG=s1_server=info,tower_http=info
