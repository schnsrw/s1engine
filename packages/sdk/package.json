{
  "name": "@s1engine/sdk",
  "version": "1.0.1",
  "description": "Headless JavaScript/TypeScript SDK for s1engine — document manipulation, format conversion, collaboration",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/schnsrw/s1engine",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
